SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here
PORTKEY_API_KEY=your-portkey-api-key-here
PORTKEY_MODEL=pilot-poc/claude-sonnet-4-5

# Slack Channel ID for fetching messages (default: #devops-help)
DEVOPS_HELP_CHANNEL_ID=C6P2C6938

# SSL Configuration (optional)
# Set to 1 to disable SSL verification (for corporate proxies with self-signed certs)
# WARNING: Only use this if you're behind a corporate proxy with SSL interception
# DISABLE_SSL_VERIFY=1

# Confluence Integration (Optional)
# Create TRM reports as Confluence pages instead of Slack messages
CONFLUENCE_URL=https://your-company.atlassian.net/wiki
CONFLUENCE_USER=your.email@company.com
CONFLUENCE_API_TOKEN=your-confluence-api-token-here
CONFLUENCE_SPACE_KEY=DEVOPS
CONFLUENCE_PARENT_ID=  # Optional - parent page ID for TRM reports

# Jira Integration (Optional)
# Fetch tickets from Jira and include in TRM reports
JIRA_URL=https://your-company.atlassian.net
JIRA_USER=your.email@company.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEYS=DEVOPS,INFRA,SRE  # Comma-separated list of project keys to search
